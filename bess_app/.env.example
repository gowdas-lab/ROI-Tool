# Copy this file to .env and change values for your target environment.
ENVIRONMENT=production

FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bess_db

DATABASE_URL=postgresql://change_me:change_me_strong_password@postgres:5432/bess_db

# Use your public API host in production
VITE_API_URL=http://localhost:8000

# Use your frontend domain(s) in production, comma-separated if needed
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
