# Copy this file to .env and change values for your target environment.
ENVIRONMENT=production

FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bess_db

DATABASE_URL=postgresql://change_me:change_me_strong_password@postgres:5432/bess_db

# Use your public API host in production
VITE_API_URL=http://localhost:8000

# Use your frontend domain(s) in production, comma-separated if needed
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

# Auth token settings (stateless signed tokens)
AUTH_TOKEN_SECRET=change_me_to_a_long_random_secret
AUTH_TOKEN_TTL_SECONDS=604800

# Admin bootstrap behavior:
# Backend auto-creates a temporary admin at startup if no admin exists:
#   email: admin-bess-app@temp-mail.com
#   password: 12345admin
# To create your own initial admin, go to http://localhost:8000/bess-app-admin and log in with the temporary admin credentials, then create a new admin user.
# Once you create at least one non-temporary admin, the temporary admin is auto-deleted.
# Optional manual bootstrap script remains available:
#   python bootstrap_admin.py --email admin@example.com
